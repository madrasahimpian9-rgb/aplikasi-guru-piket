# Database Configuration for Vercel + Neon PostgreSQL
# Get your DATABASE_URL from https://neon.tech

# Connection pooling URL (used by Prisma in production)
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Direct connection URL (used for migrations)
DIRECT_DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="https://your-app.vercel.app"
