generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Guru {
  id                 String               @id @default(cuid())
  kode               String               @unique
  nama               String
  gelar              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  Jadwal             Jadwal[]
  JadwalPiket        JadwalPiket[]
  KehadiranGuru      KehadiranGuru[]
  KehadiranGuruPiket KehadiranGuruPiket[]

  @@index([nama])
}

model Jadwal {
  id            String          @id @default(cuid())
  hari          String
  jamKe         Int
  waktuMulai    String
  waktuSelesai  String
  kelasId       String
  mapelId       String?
  guruId        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  Guru          Guru            @relation(fields: [guruId], references: [id], onDelete: Cascade)
  MataPelajaran MataPelajaran?  @relation(fields: [mapelId], references: [id], onDelete: SetNull)
  Kelas         Kelas           @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  KehadiranGuru KehadiranGuru[]

  @@unique([hari, jamKe, kelasId])
  @@index([kelasId])
  @@index([guruId])
  @@index([hari])
}

model JadwalPiket {
  id        String   @id @default(cuid())
  hari      String
  shift     String
  guruId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Guru      Guru     @relation(fields: [guruId], references: [id], onDelete: Cascade)

  @@unique([hari, shift])
  @@index([hari])
}

model KehadiranGuru {
  id         String   @id @default(cuid())
  tanggal    DateTime @db.Date
  jadwalId   String
  guruId     String
  status     String
  keterangan String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  Guru       Guru     @relation(fields: [guruId], references: [id], onDelete: Cascade)
  Jadwal     Jadwal   @relation(fields: [jadwalId], references: [id], onDelete: Cascade)

  @@unique([tanggal, jadwalId])
  @@index([status])
  @@index([guruId])
  @@index([tanggal])
}

model KehadiranGuruPiket {
  id         String   @id @default(cuid())
  tanggal    DateTime @db.Date
  guruId     String
  shift      String
  status     String
  keterangan String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  Guru       Guru     @relation(fields: [guruId], references: [id], onDelete: Cascade)

  @@unique([tanggal, guruId, shift])
  @@index([shift])
  @@index([tanggal])
}

model KehadiranSiswa {
  id         String   @id @default(cuid())
  tanggal    DateTime @db.Date
  siswaId    String
  kelasId    String
  status     String
  keterangan String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  Kelas      Kelas    @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  Siswa      Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@unique([tanggal, siswaId])
  @@index([status])
  @@index([kelasId])
  @@index([tanggal])
}

model Kelas {
  id             String           @id @default(cuid())
  nama           String           @unique
  tingkat        Int
  shift          String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  Jadwal         Jadwal[]
  KehadiranSiswa KehadiranSiswa[]
  Siswa          Siswa[]

  @@index([shift])
}

model MataPelajaran {
  id        String   @id @default(cuid())
  kode      String   @unique
  nama      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Jadwal    Jadwal[]
}

model Pengaturan {
  id            String   @id @default(cuid())
  namaSekolah   String
  alamatSekolah String?
  telepon       String?
  email         String?
  kepalaSekolah String?
  semester      String
  tahunAjaran   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  logo          String?
}

model Siswa {
  id             String           @id @default(cuid())
  nama           String
  kelasId        String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  KehadiranSiswa KehadiranSiswa[]
  Kelas          Kelas            @relation(fields: [kelasId], references: [id], onDelete: Cascade)

  @@index([nama])
  @@index([kelasId])
}
